PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/ssl-pilot

# ACME (Let's Encrypt)
ACME_EMAIL=your-email@example.com
ACME_STAGING=true
# base64-encoded PEM key — copy from startup warning log on first run
ACME_ACCOUNT_KEY=

# Security (Vault)
# Generate a 64-char hex string: openssl rand -hex 32
VAULT_MASTER_KEY=

# JWT Secrets
JWT_ACCESS_SECRET=your-access-secret
JWT_REFRESH_SECRET=your-refresh-secret

# Frontend
FRONTEND_URL=https://your-domain.com